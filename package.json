{
  "name": "custom-map-website",
  "version": "1.0.0",
  "description": "A custom map website with location groups storage",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "colors:build": "node scripts/computeZipCaColors.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "db"
    ],
    "ext": "js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "multer": "^2.0.1",
    "shapefile": "^0.6.6",
    "pg": "^8.13.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "maps",
    "locations",
    "express",
    "nodejs"
  ],
  "author": "",
  "license": "MIT"
}
